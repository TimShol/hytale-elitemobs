            Group #TabWorldVisuals { LayoutMode: Top; Visible: false;

              Label { Text: "MODEL SCALING"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }

              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Enable Model Scaling"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                Group { Anchor: (Width: 38, Height: 28); TextButton #EnableModelScalingOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EnableModelScalingOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                Label { Text: "Scale elite size by tier"; Anchor: (Left: 16); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ModifiedEnableModelScaling { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }

              Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
              Label { Text: "Scale Multiplier Per Tier"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Top; Anchor: (Left: 0, Width: 410);
                Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                  Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Background: (Color: #1e2530);
                  $C.@TextField #FieldModelScale0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldModelScale1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldModelScale2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldModelScale3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldModelScale4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Label #ModifiedModelScale { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                }
              }

              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Size Variance"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldModelVariance { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedModelVariance { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "Random +/- size factor (e.g. 0.04 = 4%)"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
              }

              Group {
                Anchor: (Height: 1, Top: 16, Bottom: 12);
                Background: (Color: #1a2840);
              }
              Label { Text: "NAMEPLATES"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }

              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
