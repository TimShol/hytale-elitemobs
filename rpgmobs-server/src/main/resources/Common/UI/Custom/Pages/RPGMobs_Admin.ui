                Label { Text: "0.0 - 1.0"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedLootDurMin { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Durability Max"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldLootDurMax { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedLootDurMax { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "0.0 - 1.0"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedLootDurMax { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }

              Group { Anchor: (Height: 1, Top: 16, Bottom: 12); Background: (Color: #1a2840); }
              Label { Text: "Loot Templates"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 8); }

              Group #LootBreadcrumb {
                LayoutMode: Left;
                Anchor: (Height: 30, Bottom: 8);
                Background: (Color: #0f1620);
                Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

                TextButton #LootNavBack { Text: "<"; Anchor: (Width: 28, Height: 24); Style: @PaginationButtonStyle; }
                TextButton #LootNavForward { Text: ">"; Anchor: (Width: 28, Height: 24, Left: 4); Style: @PaginationButtonStyle; }
                Label #LootBreadcrumbText { Text: "> All"; FlexWeight: 1; Anchor: (Left: 12); Style: (FontSize: 13, TextColor: #c8d6e5, VerticalAlignment: Center); }
              }

              Group #LootFilterBar { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                Label { Text: "Search Templates:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 120); }
                $C.@TextField #LootTreeFilter { Anchor: (Width: 150, Height: 26); Style: (FontSize: 13, TextColor: #c8d6e5); }
                Group { FlexWeight: 1; }
                TextButton #LootDeleteFiltered { Text: "Delete Filtered"; Anchor: (Width: 110, Height: 26); Style: @DeleteRowButtonStyle; Visible: false; }
                Group { Anchor: (Width: 4); }
                TextButton #LootDeleteAll { Text: "Delete All"; Anchor: (Width: 80, Height: 26); Style: @DeleteRowButtonStyle; }
              }

              Group #LootTreeRows {
                LayoutMode: Top;
