              Group { Anchor: (Height: 1, Top: 16, Bottom: 12); Background: (Color: #1a2840); }
              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                Label { Text: "SPAWN TIER RESTRICTIONS"; Style: @SectionHeaderStyle; FlexWeight: 1; }
                Label #ModifiedTierRestrictions { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 24); Visible: false; }
              }
              Label { Text: "Override which tiers specific mobs or categories can spawn as. Overrides progression style."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 8); }

              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
