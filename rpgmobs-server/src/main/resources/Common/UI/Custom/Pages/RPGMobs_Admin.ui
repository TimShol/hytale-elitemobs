        Group #CaiTabBar {
          LayoutMode: Left;
          Anchor: (Height: 38);
          Background: (Color: #0f1620);
          Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
          Visible: false;

          Group #CaiTabGroup0 { FlexWeight: 1; Anchor: (Height: 30); TextButton #CaiTab0 { Text: "Combat Styles"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: false; } TextButton #CaiTab0Active { Text: "Combat Styles"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: true; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #CaiTabGroup1 { FlexWeight: 1; Anchor: (Height: 30); TextButton #CaiTab1 { Text: "Tier Behavior"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #CaiTab1Active { Text: "Tier Behavior"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #CaiTabGroup2 { FlexWeight: 1; Anchor: (Height: 30); TextButton #CaiTab2 { Text: "Weapon Combat"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #CaiTab2Active { Text: "Weapon Combat"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } }
        }

        Group #ContentHeader {
          LayoutMode: Left;
          Anchor: (Height: 38);
          Padding: (Left: 24, Right: 24, Top: 8, Bottom: 0);

          Label #ContentTitle {
            Text: "Core Settings";
            Style: (TextColor: #96a9be, FontSize: 16, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
            FlexWeight: 1;
          }

          Label #DirtyIndicator {
            Text: "* Unsaved changes";
            Style: (TextColor: #e8a838, FontSize: 13, VerticalAlignment: Center);
            Anchor: (Width: 160);
            Visible: false;
          }
        }

        Group {
          Anchor: (Height: 1);
          Background: (Color: #1a2840);
        }

        Group #ContentScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 24, Right: 24, Top: 16, Bottom: 16);

            Group #TabGlobalCore {
              LayoutMode: Top;
              Visible: true;

              Group {
                LayoutMode: Left;
                Anchor: (Height: 34, Bottom: 8);

                Label {
                  Text: "RPGMobs Enabled";
                  Style: @FieldLabelStyle;
                  Anchor: (Width: 300);
                }

                Group { Anchor: (Width: 38, Height: 28); TextButton #GlobalEnabledOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #GlobalEnabledOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }

                Label {
                  Text: "Master switch  - disables ALL worlds when OFF";
                  Anchor: (Left: 16);
                  Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center);
                }
              }

              Group {
                LayoutMode: Left;
                Anchor: (Height: 34, Bottom: 8);

                Label {
                  Text: "Enabled By Default";
                  Style: @FieldLabelStyle;
                  Anchor: (Width: 300);
                }

                Group { Anchor: (Width: 38, Height: 28); TextButton #EnabledByDefaultOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EnabledByDefaultOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }

                Label {
                  Text: "Fallback for worlds without an overlay";
                  Anchor: (Left: 16);
                  Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center);
                }
              }


            }

            Group #TabGlobalDebug {
              LayoutMode: Top;
              Visible: false;

              Group {
                LayoutMode: Left;
                Anchor: (Height: 34, Bottom: 8);

                Label {
                  Text: "Debug Mode";
                  Style: @FieldLabelStyle;
                  Anchor: (Width: 300);
                }

                Group { Anchor: (Width: 38, Height: 28); TextButton #DebugModeOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #DebugModeOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }

                Label {
                  Text: "Enable verbose logging";
                  Anchor: (Left: 16);
                  Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center);
                }
              }

              Group {
                LayoutMode: Left;
                Anchor: (Height: 34, Bottom: 8);

                Label {
                  Text: "Mob Rule Scan Interval (sec)";
                  Style: @FieldLabelStyle;
                  Anchor: (Width: 300);
                }

                $C.@TextField #FieldDebugScanInterval {
                  Anchor: (Width: 50, Height: 30);
                  Style: (FontSize: 14, TextColor: #ffffff);
                }

                Label {
                  Text: "Only active when debug mode is on (1-600)";
                  Anchor: (Left: 16);
                  Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center);
                }
              }
            }

            Group #TabConfigWeapons { LayoutMode: Top; Visible: false;
              Label { Text: "Weapon Categories"; Style: @SectionHeaderStyle; Anchor: (Height: 22, Bottom: 6); }
              Label { Text: "Organize weapons into categories for mob rule weapon restrictions."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 8); }

              Group #WpnCatBreadcrumb { LayoutMode: Left; Anchor: (Height: 30, Bottom: 8); Background: (Color: #0f1620); Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
                TextButton #WpnCatNavBack { Text: "<"; Anchor: (Width: 28, Height: 24); Style: @PaginationButtonStyle; }
                TextButton #WpnCatNavForward { Text: ">"; Anchor: (Width: 28, Height: 24, Left: 4); Style: @PaginationButtonStyle; }
                Label #WpnCatBreadcrumbText { Text: "> All"; FlexWeight: 1; Anchor: (Left: 12); Style: (FontSize: 13, TextColor: #c8d6e5, VerticalAlignment: Center); }
              }

              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                Label { Text: "Search Weapons:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 120); }
                $C.@TextField #WpnCatTreeFilter { Anchor: (Width: 150, Height: 26); Style: (FontSize: 13, TextColor: #c8d6e5); }
                Group { FlexWeight: 1; }
                TextButton #WpnCatDeleteFiltered { Text: "Delete Filtered"; Anchor: (Width: 110, Height: 26); Style: @DeleteRowButtonStyle; Visible: false; }
                Group { Anchor: (Width: 4); }
                TextButton #WpnCatDeleteAll { Text: "Delete All"; Anchor: (Width: 80, Height: 26); Style: @DeleteRowButtonStyle; }
              }

              Group { LayoutMode: Top; Anchor: (Left: 0);
                Group #WpnCatRow0 { LayoutMode: Left; Anchor: (Height: 28, Bottom: 2); Visible: false; Group { Anchor: (Width: 28, Height: 28); ItemIcon #WpnCatRowIcon0 { Anchor: (Width: 28, Height: 28); Visible: false; } } TextButton #WpnCatRowCat0 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @TreeRowCategoryStyle; Padding: (Left: 8); Visible: false; } TextButton #WpnCatRowItm0 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @TreeRowItemStyle; Padding: (Left: 4); Visible: false; } TextButton #WpnCatRowRen0 { Text: "Rename"; Anchor: (Width: 56, Height: 28); Style: @SubTabStyle; } TextButton #WpnCatRowChs0 { Text: "Choose"; Anchor: (Width: 56, Height: 28); Style: @SubTabStyle; Visible: false; } TextButton #WpnCatRowMov0 { Text: "Move"; Anchor: (Width: 46, Height: 28); Style: @SubTabStyle; } TextButton #WpnCatRowDel0 { Text: "X"; Anchor: (Width: 28, Height: 28); Style: @DeleteRowButtonStyle; } }
                Group #WpnCatRow1 { LayoutMode: Left; Anchor: (Height: 28, Bottom: 2); Visible: false; Group { Anchor: (Width: 28, Height: 28); ItemIcon #WpnCatRowIcon1 { Anchor: (Width: 28, Height: 28); Visible: false; } } TextButton #WpnCatRowCat1 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @TreeRowCategoryStyle; Padding: (Left: 8); Visible: false; } TextButton #WpnCatRowItm1 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @TreeRowItemStyle; Padding: (Left: 4); Visible: false; } TextButton #WpnCatRowRen1 { Text: "Rename"; Anchor: (Width: 56, Height: 28); Style: @SubTabStyle; } TextButton #WpnCatRowChs1 { Text: "Choose"; Anchor: (Width: 56, Height: 28); Style: @SubTabStyle; Visible: false; } TextButton #WpnCatRowMov1 { Text: "Move"; Anchor: (Width: 46, Height: 28); Style: @SubTabStyle; } TextButton #WpnCatRowDel1 { Text: "X"; Anchor: (Width: 28, Height: 28); Style: @DeleteRowButtonStyle; } }
