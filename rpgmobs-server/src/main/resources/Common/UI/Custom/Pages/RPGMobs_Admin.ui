        Group #AssetPickerRow13 { LayoutMode: Left; Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #AssetPickerRowBtn13 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @TreeRowItemStyle; Padding: (Left: 8); } TextButton #AssetPickerRowBtnSel13 { Text: ""; FlexWeight: 1; Anchor: (Height: 28); Style: @AssetPickerRowSelectedStyle; Padding: (Left: 8); Visible: false; } }
