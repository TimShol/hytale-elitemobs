              Label #EffectTreeEmpty { Text: "No entity effects configured."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 24, Top: 4); Visible: false; }

              Group #EffectDetailPanel { LayoutMode: Top; Visible: false; Background: (Color: #141c26); Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
                Label #EffectDetailName { Text: ""; Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true); Anchor: (Height: 20, Bottom: 8); }

                Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 8);
                  Label { Text: "Infinite Duration"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                  Group { Anchor: (Width: 38, Height: 28); TextButton #EffectDetailInfiniteOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EffectDetailInfiniteOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                }

                Group { LayoutMode: Top; Background: (Color: #1e2530); Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4); Anchor: (Bottom: 4);
                  Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                    Label { Text: ""; Style: @ColHeaderStyle; Anchor: (Width: 100); }
                    Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 60); }
                    Group { Anchor: (Width: 6); }
                    Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 60); }
                    Group { Anchor: (Width: 6); }
                    Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 60); }
                    Group { Anchor: (Width: 6); }
                    Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 60); }
                    Group { Anchor: (Width: 6); }
                    Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 60); }
                  }
                  Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 2);
                    Label { Text: "Enabled"; Style: @FieldLabelStyle; Anchor: (Width: 100); }
                    Group { Anchor: (Width: 60, Height: 28); TextButton #EffectDetailTierOn0 { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EffectDetailTierOff0 { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                    Group { Anchor: (Width: 6); }
                    Group { Anchor: (Width: 60, Height: 28); TextButton #EffectDetailTierOn1 { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EffectDetailTierOff1 { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                    Group { Anchor: (Width: 6); }
                    Group { Anchor: (Width: 60, Height: 28); TextButton #EffectDetailTierOn2 { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #EffectDetailTierOff2 { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                    Group { Anchor: (Width: 6); }
