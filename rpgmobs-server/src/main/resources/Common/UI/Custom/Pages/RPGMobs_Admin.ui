                $C.@TextField #FieldDropOffhand { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedDropOffhand { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "0.0 - 1.0"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedDropOffhand { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }

              Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
              Label { Text: "Dropped Gear Durability"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Durability Min"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
