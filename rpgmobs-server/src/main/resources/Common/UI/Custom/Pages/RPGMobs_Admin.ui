      Group { LayoutMode: Left; Anchor: (Height: 34);
        TextButton #AssetPickerCancel { Text: "Cancel"; Anchor: (Width: 100, Height: 30); Style: @SubTabStyle; }
        Group { FlexWeight: 1; }
        TextButton #AssetPickerConfirm { Text: "Select"; Anchor: (Width: 120, Height: 30); Style: @SubTabStyle; Visible: false; }
      }
    }
  }
}
