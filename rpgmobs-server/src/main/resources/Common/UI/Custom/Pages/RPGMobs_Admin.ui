              Group #WpnCatPagination { LayoutMode: Left; Anchor: (Height: 26, Bottom: 4); Visible: false;
                Group { FlexWeight: 1; }
                Group { Anchor: (Width: 26, Height: 26); TextButton #WpnCatPrevPage { Text: "<"; Anchor: (Width: 26, Height: 26); Style: @PaginationButtonStyle; } }
                Label #WpnCatPageInfo { Text: "1 / 1"; Style: (FontSize: 13, TextColor: #5a6d82, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80, Height: 26); }
                Group { Anchor: (Width: 26, Height: 26); TextButton #WpnCatNextPage { Text: ">"; Anchor: (Width: 26, Height: 26); Style: @PaginationButtonStyle; } }
                Group { FlexWeight: 1; }
              }

              Group { LayoutMode: Left; Anchor: (Height: 34, Top: 12);
                TextButton #WpnCatAddCategory { Text: "[+] Category"; Anchor: (Width: 120, Height: 30); Style: @SubTabStyle; }
                TextButton #WpnCatAddItem { Text: "[+] Item"; Anchor: (Width: 100, Height: 30, Left: 8); Style: @SubTabStyle; }
              }
            }

            Group #TabConfigArmor { LayoutMode: Top; Visible: false;
              Label { Text: "Armor Categories"; Style: @SectionHeaderStyle; Anchor: (Height: 22, Bottom: 6); }
              Label { Text: "Organize armor materials into categories for mob rule armor restrictions."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 8); }

              Group #ArmCatBreadcrumb { LayoutMode: Left; Anchor: (Height: 30, Bottom: 8); Background: (Color: #0f1620); Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
                TextButton #ArmCatNavBack { Text: "<"; Anchor: (Width: 28, Height: 24); Style: @PaginationButtonStyle; }
                TextButton #ArmCatNavForward { Text: ">"; Anchor: (Width: 28, Height: 24, Left: 4); Style: @PaginationButtonStyle; }
                Label #ArmCatBreadcrumbText { Text: "> All"; FlexWeight: 1; Anchor: (Left: 12); Style: (FontSize: 13, TextColor: #c8d6e5, VerticalAlignment: Center); }
              }

              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                Label { Text: "Search Armor:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 100); }
                $C.@TextField #ArmCatTreeFilter { Anchor: (Width: 150, Height: 26); Style: (FontSize: 13, TextColor: #c8d6e5); }
                Group { FlexWeight: 1; }
                TextButton #ArmCatDeleteFiltered { Text: "Delete Filtered"; Anchor: (Width: 110, Height: 26); Style: @DeleteRowButtonStyle; Visible: false; }
                Group { Anchor: (Width: 4); }
                TextButton #ArmCatDeleteAll { Text: "Delete All"; Anchor: (Width: 80, Height: 26); Style: @DeleteRowButtonStyle; }
              }

              Group { LayoutMode: Top; Anchor: (Left: 0);
