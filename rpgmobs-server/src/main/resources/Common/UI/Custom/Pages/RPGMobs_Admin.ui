                Label #ChangedGlobalCdMax { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedGlobalCdMax { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Group { Anchor: (Height: 1, Top: 8, Bottom: 10); Background: (Color: #2a3a4a); }
              Label { Text: "Per-Ability Configuration"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Label { Text: "Toggle abilities, per-tier gates, and linked mob rules per world."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 18, Bottom: 8); }

