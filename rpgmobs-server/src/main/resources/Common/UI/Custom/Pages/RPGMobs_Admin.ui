      }

      Label #AssetPickerEmpty { Text: "No assets match filter."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 18); Visible: false; }

      Group #AssetPickerPagination { LayoutMode: Left; Anchor: (Height: 28, Top: 4); Visible: false;
        Group { FlexWeight: 1; }
        Group { Anchor: (Width: 26, Height: 26); TextButton #AssetPickerFirstPage { Text: "<<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
        Group { Anchor: (Width: 2); }
        Group { Anchor: (Width: 26, Height: 26); TextButton #AssetPickerPrevPage { Text: "<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
