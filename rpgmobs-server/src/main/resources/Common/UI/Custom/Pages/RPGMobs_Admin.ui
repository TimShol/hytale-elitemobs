  Group #RenamePopup {
    Anchor: (Width: 1200, Height: 880);
    Background: (Color: #00000080);
    Visible: false;

    TextButton #RenamePopupBackdrop { Text: ""; Anchor: (Width: 1200, Height: 880); Style: @BackdropStyle; }

    Group {
      Anchor: (Width: 360, Height: 160);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 16, Right: 16, Top: 14, Bottom: 14);

      Label #RenamePopupTitle { Text: "Rename"; Style: (FontSize: 15, TextColor: #c8d6e5, RenderBold: true); Anchor: (Height: 24, Bottom: 8); }

      Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 8);
        Label { Text: "Name:"; Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 50); }
        $C.@TextField #RenamePopupField { Anchor: (Width: 260, Height: 26); Style: (FontSize: 14, TextColor: #c8d6e5); }
      }

      Group { LayoutMode: Left; Anchor: (Height: 34, Top: 8);
        TextButton #RenamePopupCancel { Text: "Cancel"; Anchor: (Width: 100, Height: 30); Style: @SubTabStyle; }
        Group { FlexWeight: 1; }
        TextButton #RenamePopupConfirm { Text: "Rename"; Anchor: (Width: 140, Height: 30); Style: @SaveButtonStyle; }
      }
    }
  }

