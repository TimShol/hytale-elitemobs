$C = "../Common.ui";

@BackdropStyle = TextButtonStyle(
  Default: (Background: #00000001, LabelStyle: (FontSize: 1, TextColor: #00000000)),
  Hovered: (Background: #00000001, LabelStyle: (FontSize: 1, TextColor: #00000000)),
  Pressed: (Background: #00000001, LabelStyle: (FontSize: 1, TextColor: #00000000))
);

@SidebarNavStyle = TextButtonStyle(
  Default: (Background: #0d1520, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0a1119, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SidebarNavActiveStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SidebarNavChangedStyle = TextButtonStyle(
  Default: (Background: #0d1520, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #f0c050, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0a1119, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SidebarNavChangedActiveStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #f0c050, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@SubTabStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SubTabActiveStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SubTabChangedStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #f0c050, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SubTabChangedActiveStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 13, TextColor: #f0c050, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 13, TextColor: #e8a838, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@DropdownOptionStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: false, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@DropdownOptionActiveStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SaveButtonStyle = TextButtonStyle(
  Default: (Background: #2d6b3f, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a8a50, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #225530, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@SaveAssetReloadStyle = TextButtonStyle(
  Default: (Background: #8b6b2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #a07b3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7a5b1a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@DiscardButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@CloseButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@PeacefulButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a6b, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a7b, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a5b, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@PaginationButtonStyle = TextButtonStyle(
  Default: (Background: #1a2840, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #243650, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f1824, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@DeleteRowButtonStyle = TextButtonStyle(
  Default: (Background: #6b2a2a, LabelStyle: (FontSize: 13, TextColor: #ff8888, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #8b3a3a, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #4a1818, LabelStyle: (FontSize: 13, TextColor: #ff8888, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@FieldLabelStyle = (FontSize: 14, TextColor: #c8d6e5, VerticalAlignment: Center);
@FieldValueStyle = (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center);
@SectionHeaderStyle = (TextColor: #5a6d82, FontSize: 13, RenderBold: true, RenderUppercase: true, LetterSpacing: 2);
@ColHeaderStyle = (FontSize: 13, TextColor: #7a8fa8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);

@TreeRowCategoryStyle = TextButtonStyle(
  Default: (Background: #1a2a4a, LabelStyle: (FontSize: 13, TextColor: #8ab4f8, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #243a5a, LabelStyle: (FontSize: 13, TextColor: #aaccff, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0f1a30, LabelStyle: (FontSize: 13, TextColor: #8ab4f8, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@CategoryNameStyle = TextButtonStyle(
  Default: (Background: #00000000, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #ffffff10, LabelStyle: (FontSize: 13, TextColor: #e0eaf5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #00000020, LabelStyle: (FontSize: 13, TextColor: #c8d6e5, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@TreeRowItemStyle = TextButtonStyle(
  Default: (Background: #1a3a2a, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #244a3a, LabelStyle: (FontSize: 13, TextColor: #6aee9a, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #0f2018, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@TreeRowItemDisabledStyle = TextButtonStyle(
  Default: (Background: #1e2530, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #252e3a, LabelStyle: (FontSize: 13, TextColor: #728898, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #171d26, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: false, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@AssetPickerRowSelectedStyle = TextButtonStyle(
  Default: (Background: #1a4a3a, LabelStyle: (FontSize: 13, TextColor: #4ae04a, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Hovered: (Background: #1a4a3a, LabelStyle: (FontSize: 13, TextColor: #4ae04a, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center)),
  Pressed: (Background: #1a4a3a, LabelStyle: (FontSize: 13, TextColor: #4ae04a, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center))
);

@ToggleOnStyle = TextButtonStyle(
  Default: (Background: #1a3a2a, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #244a3a, LabelStyle: (FontSize: 13, TextColor: #6aee9a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0f2018, LabelStyle: (FontSize: 13, TextColor: #4ade80, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

@ToggleOffStyle = TextButtonStyle(
  Default: (Background: #1e2530, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #252e3a, LabelStyle: (FontSize: 13, TextColor: #728898, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #171d26, LabelStyle: (FontSize: 13, TextColor: #5a6d82, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
);

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 1200, Height: 880);

    #Title {
      Group {
        LayoutMode: Left;

        Group {
          Anchor: (Width: 40, Height: 28);
        }

        Group {
          FlexWeight: 1;
          $C.@Title {
            @Text = "RPGMobs Config";
          }
        }

        Group {
          Anchor: (Width: 40, Height: 28);
          TextButton #CloseButton {
            Text: "X";
            Anchor: (Width: 32, Height: 28);
            Style: @CloseButtonStyle;
          }
        }
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Left: 0, Right: 0, Top: 0, Bottom: 0);

      Group #Sidebar {
        Anchor: (Width: 250);
        Background: (Color: #0a1119);
        LayoutMode: Top;
        Padding: (Left: 14, Right: 14, Top: 12, Bottom: 12);

        Label {
          Text: "GLOBAL";
          Style: @SectionHeaderStyle;
          Anchor: (Height: 18, Bottom: 6);
        }

        Group #NavGlobalCoreGroup {
          Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGlobalCore { Text: "Core"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalCoreActive { Text: "Core"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: true; }
          TextButton #NavGlobalCoreChanged { Text: "Core"; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalCoreChangedActive { Text: "Core"; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; }
        }

        Group #NavGlobalDebugGroup {
          Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGlobalDebug { Text: "Debug"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; }
          TextButton #NavGlobalDebugActive { Text: "Debug"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalDebugChanged { Text: "Debug"; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalDebugChangedActive { Text: "Debug"; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; }
        }

        Group #NavGlobalMobRulesGroup {
          Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGlobalMobRules { Text: "Mob Rules"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; }
          TextButton #NavGlobalMobRulesActive { Text: "Mob Rules"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalMobRulesChanged { Text: "Mob Rules"; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalMobRulesChangedActive { Text: "Mob Rules"; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; }
        }

        Group #NavGlobalCombatAIGroup {
          Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGlobalCombatAI { Text: "Combat AI"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; }
          TextButton #NavGlobalCombatAIActive { Text: "Combat AI"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalCombatAIChanged { Text: "Combat AI"; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalCombatAIChangedActive { Text: "Combat AI"; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; }
        }

        Group #NavGlobalConfigGroup {
          Anchor: (Height: 28, Bottom: 3);
          TextButton #NavGlobalConfig { Text: "Equipment"; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; }
          TextButton #NavGlobalConfigActive { Text: "Equipment"; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalConfigChanged { Text: "Equipment"; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; }
          TextButton #NavGlobalConfigChangedActive { Text: "Equipment"; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; }
        }


        Group {
          Anchor: (Height: 1, Top: 8, Bottom: 10);
          Background: (Color: #1a2840);
        }

        Label {
          Text: "WORLDS";
          Style: @SectionHeaderStyle;
          Anchor: (Height: 18, Bottom: 6);
        }

        Group { Anchor: (Height: 266);
          Group { LayoutMode: Top;
            Group #NavWorldGroup0 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld0 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld0Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld0Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld0ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup1 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld1 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld1Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld1Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld1ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup2 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld2 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld2Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld2Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld2ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup3 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld3 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld3Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld3Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld3ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup4 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld4 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld4Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld4Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld4ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup5 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld5 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld5Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld5Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld5ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup6 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld6 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld6Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld6Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld6ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavWorldGroup7 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavWorld7 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavWorld7Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld7Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavWorld7ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
          }
          Group #WorldPagination { LayoutMode: Left; Anchor: (Height: 24, Top: 240); Visible: false;
            Group { FlexWeight: 1; }
            Group { Anchor: (Width: 26, Height: 24); TextButton #FirstWorlds { Text: "<<"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 2); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #PrevWorlds { Text: "<"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 4); }
            Label #WorldPageLabel { Text: "1/1"; Style: (FontSize: 13, TextColor: #5a6d82, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80, Height: 24); }
            Group { Anchor: (Width: 4); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #NextWorlds { Text: ">"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 2); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #LastWorlds { Text: ">>"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { FlexWeight: 1; }
          }
        }

        Group {
          Anchor: (Height: 1, Top: 8, Bottom: 10);
          Background: (Color: #1a2840);
        }

        Label {
          Text: "INSTANCES";
          Style: @SectionHeaderStyle;
          Anchor: (Height: 18, Bottom: 6);
        }

        Group { Anchor: (Height: 266);
          Group { LayoutMode: Top;
            Group #NavInstGroup0 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst0 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst0Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst0Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst0ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavInstGroup1 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst1 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst1Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst1Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst1ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
