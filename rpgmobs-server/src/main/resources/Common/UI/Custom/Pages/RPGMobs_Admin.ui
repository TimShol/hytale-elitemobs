              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Fall Damage Disabled"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                Group { Anchor: (Width: 38, Height: 28); TextButton #FallDamageOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #FallDamageOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                Label { Text: "Elites take no fall damage"; Anchor: (Left: 16); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedFallDamage { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedFallDamage { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }

              Group {
                Anchor: (Height: 1, Top: 16, Bottom: 12);
                Background: (Color: #1a2840);
              }
              Label { Text: "APPLY PRESET"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 8); }
              Label { Text: "Populate all overlay fields from a preset. Review values in each tab before saving."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 24, Bottom: 8); }
              Group { LayoutMode: Left; Anchor: (Height: 36, Bottom: 4);
                Group { Anchor: (Width: 110, Height: 32); TextButton #PresetFull { Text: "Default"; Anchor: (Height: 32); Style: @SubTabStyle; Visible: true; } TextButton #PresetFullActive { Text: "Default"; Anchor: (Height: 32); Style: @SubTabActiveStyle; Visible: false; } }
                Group { Anchor: (Width: 6); }
                Group { Anchor: (Width: 110, Height: 32); TextButton #PresetEmpty { Text: "Empty"; Anchor: (Height: 32); Style: @SubTabStyle; Visible: true; } TextButton #PresetEmptyActive { Text: "Empty"; Anchor: (Height: 32); Style: @SubTabActiveStyle; Visible: false; } }
                Group { Anchor: (Width: 6); }
                Group { Anchor: (Width: 140, Height: 32); TextButton #PresetCustom { Text: "World Custom"; Anchor: (Height: 32); Style: @SubTabStyle; Visible: false; } TextButton #PresetCustomActive { Text: "World Custom"; Anchor: (Height: 32); Style: @SubTabActiveStyle; Visible: false; } TextButton #PresetCustomOff { Text: "World Custom"; Anchor: (Height: 32); Style: @ToggleOffStyle; Visible: true; } }
                Group { Anchor: (Width: 6); }
                Group { Anchor: (Width: 150, Height: 32); TextButton #PresetGlobal { Text: "Global Custom"; Anchor: (Height: 32); Style: @SubTabStyle; Visible: false; } TextButton #PresetGlobalActive { Text: "Global Custom"; Anchor: (Height: 32); Style: @SubTabActiveStyle; Visible: false; } TextButton #PresetGlobalOff { Text: "Global Custom"; Anchor: (Height: 32); Style: @ToggleOffStyle; Visible: true; } }
              }
              Group { LayoutMode: Left; Anchor: (Height: 30, Top: 4, Bottom: 4);
                TextButton #SaveWorldCustomPreset { Text: "Save World Custom"; Anchor: (Width: 190, Height: 28); Style: @SubTabStyle; }
                Group { Anchor: (Width: 8); }
                TextButton #SaveGlobalCustomPreset { Text: "Save Global Custom"; Anchor: (Width: 190, Height: 28); Style: @SubTabStyle; }
                Label { Text: "Snapshot current config as a reusable preset"; Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); Anchor: (Height: 28); Padding: (Left: 10); }
              }
              Label #PresetAppliedMsg { Text: ""; Style: (FontSize: 13, TextColor: #4ade80); Anchor: (Height: 20, Top: 4); Visible: false; }
            }

            Group #TabWorldSpawning { LayoutMode: Top; Visible: false;

              Label { Text: "Progression Style"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 4);
                Group { Anchor: (Width: 180, Height: 30); TextButton #ProgStyleEnv { Text: "Environment"; Anchor: (Height: 30); Style: @DropdownOptionStyle; Visible: false; } TextButton #ProgStyleEnvActive { Text: "Environment"; Anchor: (Height: 30); Style: @DropdownOptionActiveStyle; Visible: true; } }
                Group { Anchor: (Width: 8); }
                Group { Anchor: (Width: 180, Height: 30); TextButton #ProgStyleDist { Text: "Distance"; Anchor: (Height: 30); Style: @DropdownOptionStyle; Visible: true; } TextButton #ProgStyleDistActive { Text: "Distance"; Anchor: (Height: 30); Style: @DropdownOptionActiveStyle; Visible: false; } }
                Group { Anchor: (Width: 8); }
                Group { Anchor: (Width: 180, Height: 30); TextButton #ProgStyleNone { Text: "None"; Anchor: (Height: 30); Style: @DropdownOptionStyle; Visible: true; } TextButton #ProgStyleNoneActive { Text: "None"; Anchor: (Height: 30); Style: @DropdownOptionActiveStyle; Visible: false; } }
              }
              Group { LayoutMode: Left; Anchor: (Height: 20, Bottom: 8);
                Label #ProgStyleDescription { Text: "Tier based on the biome/zone the mob spawns in."; Style: (FontSize: 13, TextColor: #7a8da0); FlexWeight: 1; }
                Label #ChangedProgStyle { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedProgStyle { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }

              Group #SpawnChanceGroup { LayoutMode: Top; Visible: false;
                Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
                Label { Text: "Spawn Weight Per Tier"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
                Group { LayoutMode: Top; Anchor: (Left: 0, Width: 410);
                  Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                    Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  }
                  Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Background: (Color: #1e2530);
                    $C.@TextField #FieldSpawnChance0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 12); }
                    $C.@TextField #FieldSpawnChance1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 12); }
                    $C.@TextField #FieldSpawnChance2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 12); }
                    $C.@TextField #FieldSpawnChance3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 12); }
                    $C.@TextField #FieldSpawnChance4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Label #ChangedSpawnChance { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                    Label #ModifiedSpawnChance { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                  }
                }
              }

              Group #DistanceFieldsGroup { LayoutMode: Top; Visible: false;
                Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
                Label { Text: "Distance From Spawn Settings"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                  Label { Text: "Distance Per Tier"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                  $C.@TextField #FieldDistancePerTier { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Label #ModifiedDistPerTier { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                  Label { Text: "Blocks between tier zones"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
