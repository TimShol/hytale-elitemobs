                Label #ChangedNameplateMode { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedNameplateMode { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
