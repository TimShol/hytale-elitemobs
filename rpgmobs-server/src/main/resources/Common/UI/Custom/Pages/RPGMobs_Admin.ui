                    Label { Text: "Multiplier"; Style: @FieldLabelStyle; Anchor: (Width: 100); }
                    $C.@TextField #EffectDetailMult0 { Anchor: (Width: 60, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 6); }
                    $C.@TextField #EffectDetailMult1 { Anchor: (Width: 60, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 6); }
                    $C.@TextField #EffectDetailMult2 { Anchor: (Width: 60, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                    Group { Anchor: (Width: 6); }
