            Group #NavInstGroup4 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst4 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst4Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst4Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst4ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavInstGroup5 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst5 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst5Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst5Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst5ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavInstGroup6 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst6 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst6Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst6Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst6ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
            Group #NavInstGroup7 { Anchor: (Height: 28, Bottom: 2); Visible: false; TextButton #NavInst7 { Text: ""; Anchor: (Height: 28); Style: @SidebarNavStyle; Padding: (Left: 12); Visible: true; } TextButton #NavInst7Active { Text: ""; Anchor: (Height: 28); Style: @SidebarNavActiveStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst7Changed { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedStyle; Padding: (Left: 12); Visible: false; } TextButton #NavInst7ChangedActive { Text: ""; Anchor: (Height: 28); Style: @SidebarNavChangedActiveStyle; Padding: (Left: 12); Visible: false; } }
          }
          Group #InstPagination { LayoutMode: Left; Anchor: (Height: 24, Top: 240); Visible: false;
            Group { FlexWeight: 1; }
            Group { Anchor: (Width: 26, Height: 24); TextButton #FirstInsts { Text: "<<"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 2); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #PrevInsts { Text: "<"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 4); }
            Label #InstPageLabel { Text: "1/1"; Style: (FontSize: 13, TextColor: #5a6d82, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80, Height: 24); }
            Group { Anchor: (Width: 4); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #NextInsts { Text: ">"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { Anchor: (Width: 2); }
            Group { Anchor: (Width: 26, Height: 24); TextButton #LastInsts { Text: ">>"; Anchor: (Width: 26, Height: 24); Style: @PaginationButtonStyle; } }
            Group { FlexWeight: 1; }
          }
        }

        Label #VersionLabel {
          Text: "RPGMobs";
          Style: (FontSize: 10, TextColor: #3a4a5a, HorizontalAlignment: Center);
          Anchor: (Height: 16, Top: 6);
        }
      }

      Group #MainContent {
        FlexWeight: 1;
        Background: (Color: #141c26);
        LayoutMode: Top;
        Padding: (Left: 0, Right: 0, Top: 0, Bottom: 0);

        Group #SubTabBar {
          LayoutMode: Left;
          Anchor: (Height: 38);
          Background: (Color: #0f1620);
          Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

          Group #SubTabGroup0 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab0 { Text: "General"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: false; } TextButton #SubTab0Active { Text: "General"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: true; } TextButton #SubTab0Changed { Text: "General"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab0ChangedActive { Text: "General"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup1 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab1 { Text: "Mobs"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab1Active { Text: "Mobs"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab1Changed { Text: "Mobs"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab1ChangedActive { Text: "Mobs"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup2 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab2 { Text: "Stats"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab2Active { Text: "Stats"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab2Changed { Text: "Stats"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab2ChangedActive { Text: "Stats"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup3 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab3 { Text: "Loot"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab3Active { Text: "Loot"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab3Changed { Text: "Loot"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab3ChangedActive { Text: "Loot"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup4 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab4 { Text: "Spawning"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab4Active { Text: "Spawning"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab4Changed { Text: "Spawning"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab4ChangedActive { Text: "Spawning"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup5 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab5 { Text: "Effects"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab5Active { Text: "Effects"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab5Changed { Text: "Effects"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab5ChangedActive { Text: "Effects"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup6 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab6 { Text: "Abilities"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab6Active { Text: "Abilities"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab6Changed { Text: "Abilities"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab6ChangedActive { Text: "Abilities"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
          Group { Anchor: (Width: 4, Height: 30); }
          Group #SubTabGroup7 { FlexWeight: 1; Anchor: (Height: 30); Visible: false; TextButton #SubTab7 { Text: "Visuals"; Anchor: (Height: 30); Style: @SubTabStyle; Visible: true; } TextButton #SubTab7Active { Text: "Visuals"; Anchor: (Height: 30); Style: @SubTabActiveStyle; Visible: false; } TextButton #SubTab7Changed { Text: "Visuals"; Anchor: (Height: 30); Style: @SubTabChangedStyle; Visible: false; } TextButton #SubTab7ChangedActive { Text: "Visuals"; Anchor: (Height: 30); Style: @SubTabChangedActiveStyle; Visible: false; } }
