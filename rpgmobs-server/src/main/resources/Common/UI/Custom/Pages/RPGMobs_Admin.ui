              Label #AbilTreeEmpty { Text: "No abilities found."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 24, Top: 4); Visible: false; }

              Group #AbilDetailPanel { LayoutMode: Top; Visible: false; Background: (Color: #141c26); Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
                Group { LayoutMode: Left; Anchor: (Height: 20, Bottom: 2);
                  Label #AbilDetailName { Text: ""; Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true); }
                  Label #ModifiedAbilDetail { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 16); Visible: false; }
                  Label #ChangedAbilDetail { Text: " *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 16); Visible: false; }
                }
                Group { Anchor: (Height: 1, Top: 2, Bottom: 6); Background: (Color: #2a3a4a); }

                Group #AbilCfgSection { LayoutMode: Top; Anchor: (Bottom: 2);
                  Label { Text: "Weapon Gate"; Style: @SectionHeaderStyle; Anchor: (Height: 18, Bottom: 2); }
                  Label { Text: "Only elites holding weapons from these categories can use this ability. Leave empty for all weapons."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 3); }
                  Group { LayoutMode: Left; Anchor: (Height: 26, Bottom: 2);
                    TextButton #AbilCfgGateAdd { Text: "+ Add Category"; Anchor: (Width: 120, Height: 24); Style: @SubTabStyle; }
                  }
                  Group #AbilCfgGateRow0 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false; Label #AbilCfgGateName0 { Text: ""; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); } Group { Anchor: (Width: 24, Height: 22); TextButton #AbilCfgGatePeek0 { Text: ">"; Anchor: (Width: 24, Height: 22); Style: @SubTabStyle; } } Group { Anchor: (Width: 4); } TextButton #AbilCfgGateDel0 { Text: "X"; Anchor: (Width: 24, Height: 22); Style: @DeleteRowButtonStyle; } }
                  Group #AbilCfgGateRow1 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false; Label #AbilCfgGateName1 { Text: ""; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); } Group { Anchor: (Width: 24, Height: 22); TextButton #AbilCfgGatePeek1 { Text: ">"; Anchor: (Width: 24, Height: 22); Style: @SubTabStyle; } } Group { Anchor: (Width: 4); } TextButton #AbilCfgGateDel1 { Text: "X"; Anchor: (Width: 24, Height: 22); Style: @DeleteRowButtonStyle; } }
