                Group { Anchor: (Width: 26, Height: 26); TextButton #ArmCatNextPage { Text: ">"; Anchor: (Width: 26, Height: 26); Style: @PaginationButtonStyle; } }
                Group { FlexWeight: 1; }
              }

              Group { LayoutMode: Left; Anchor: (Height: 34, Top: 12);
                TextButton #ArmCatAddCategory { Text: "[+] Category"; Anchor: (Width: 120, Height: 30); Style: @SubTabStyle; }
                TextButton #ArmCatAddItem { Text: "[+] Material"; Anchor: (Width: 100, Height: 30, Left: 8); Style: @SubTabStyle; }
              }
            }

            Group #TabConfigRarityTiers { LayoutMode: Top; Visible: false;
              Label { Text: "Rarity & Tier Settings"; Style: @SectionHeaderStyle; Anchor: (Height: 22, Bottom: 6); }
              Label { Text: "Configure weapon/armor rarity rules, tier weights, and misc gear settings."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 8); }

              Group { Anchor: (Height: 1, Bottom: 8); Background: (Color: #1a2840); }
              Label { Text: "Per-Tier Equipment"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 4); }
              Label { Text: "How many armor pieces and shield chance each tier gets when spawning."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); }
              Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 2, Bottom: 2, Left: 8); Anchor: (Height: 22, Bottom: 2);
                Label { Text: "Setting"; Style: @ColHeaderStyle; Anchor: (Width: 140); }
                Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                Group { Anchor: (Width: 14); }
                Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                Group { Anchor: (Width: 14); }
                Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                Group { Anchor: (Width: 14); }
                Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                Group { Anchor: (Width: 14); }
                Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
              }
              Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 2); Background: (Color: #1e2530); Padding: (Left: 8);
                Label { Text: "Armor Pieces"; Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); Anchor: (Width: 140); }
                $C.@TextField #FieldRarityArmorPieces0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityArmorPieces1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityArmorPieces2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityArmorPieces3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityArmorPieces4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
              }
              Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 6); Background: (Color: #1e2530);
                Label { Text: "Shield Chance"; Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center); Anchor: (Width: 140); }
                $C.@TextField #FieldRarityShieldChance0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityShieldChance1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityShieldChance2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityShieldChance3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Group { Anchor: (Width: 14); }
                $C.@TextField #FieldRarityShieldChance4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
              }

              Group { Anchor: (Height: 1, Bottom: 8); Background: (Color: #1a2840); }
              Label { Text: "Tier Allowed Rarities"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 4); }
              Label { Text: "Which equipment rarities are allowed to spawn at each tier."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); }
              Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 2, Bottom: 2, Left: 8); Anchor: (Height: 22, Bottom: 2);
                Label { Text: "Tier"; Style: @ColHeaderStyle; Anchor: (Width: 40); }
                Label { Text: "Common"; Style: @ColHeaderStyle; Anchor: (Width: 90); }
                Group { Anchor: (Width: 8); }
                Label { Text: "Uncommon"; Style: @ColHeaderStyle; Anchor: (Width: 90); }
                Group { Anchor: (Width: 8); }
                Label { Text: "Rare"; Style: @ColHeaderStyle; Anchor: (Width: 90); }
                Group { Anchor: (Width: 8); }
                Label { Text: "Epic"; Style: @ColHeaderStyle; Anchor: (Width: 90); }
                Group { Anchor: (Width: 8); }
                Label { Text: "Legendary"; Style: @ColHeaderStyle; Anchor: (Width: 90); }
              }
