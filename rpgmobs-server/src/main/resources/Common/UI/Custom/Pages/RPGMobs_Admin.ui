            Group #TabWorldLoot { LayoutMode: Top; Visible: false;
              Label { Text: "Vanilla Extra Rolls Per Tier"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Top; Anchor: (Left: 0, Width: 410);
                Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                  Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Background: (Color: #1e2530);
                  $C.@TextField #FieldExtraRolls0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldExtraRolls1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldExtraRolls2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldExtraRolls3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldExtraRolls4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Label #ChangedExtraRolls { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                  Label #ModifiedExtraRolls { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                }
              }
              Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
              Label { Text: "Drop Chances"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Weapon Drop Chance"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldDropWeapon { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedDropWeapon { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "0.0 - 1.0"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedDropWeapon { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Armor Piece Drop Chance"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldDropArmor { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedDropArmor { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "0.0 - 1.0"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
                Label #ChangedDropArmor { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
