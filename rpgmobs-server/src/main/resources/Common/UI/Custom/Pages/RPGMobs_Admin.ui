      Group { Anchor: (Height: 1, Top: 8, Bottom: 8); Background: (Color: #2a3a4a); }

      Group { LayoutMode: Left; Anchor: (Height: 22, Bottom: 6);
        Label { Text: "Selected:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 70); }
        Label #AssetPickerSelectedLabel { Text: "None"; Style: (FontSize: 14, TextColor: #4ae04a, VerticalAlignment: Center); FlexWeight: 1; }
