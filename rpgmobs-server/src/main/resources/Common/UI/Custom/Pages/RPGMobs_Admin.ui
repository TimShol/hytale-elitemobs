              Label #TierOvrEmpty { Text: "No tier restrictions. Use [+] Category or [+] Mob Rule to add."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 24, Top: 4); Visible: false; }

              Group #TierOvrPagination { LayoutMode: Left; Anchor: (Height: 30, Top: 8); Visible: false;
                Group { FlexWeight: 1; }
                Group { Anchor: (Width: 26, Height: 26); TextButton #TierOvrFirstPage { Text: "<<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
                Group { Anchor: (Width: 2); }
                Group { Anchor: (Width: 26, Height: 26); TextButton #TierOvrPrevPage { Text: "<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
                Label #TierOvrPageInfo { Text: "0/0"; Style: (FontSize: 13, TextColor: #c8d6e5, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80); }
                Group { Anchor: (Width: 26, Height: 26); TextButton #TierOvrNextPage { Text: ">"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
                Group { Anchor: (Width: 2); }
                Group { Anchor: (Width: 26, Height: 26); TextButton #TierOvrLastPage { Text: ">>"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
                Group { FlexWeight: 1; }
              }
            }

            Group #TabWorldStats { LayoutMode: Top; Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 6);
                Label { Text: "Health Scaling"; Style: @SectionHeaderStyle; Anchor: (Width: 160, Height: 20); }
                Group { Anchor: (Width: 38, Height: 28); TextButton #HealthScalingOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #HealthScalingOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                Label #ChangedHealthScaling { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedHealthScaling { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Label { Text: "Scales elite HP by a multiplier per tier. Disable to use vanilla health values."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); }
              Label { Text: "Health Multiplier Per Tier"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Top; Anchor: (Left: 0, Width: 410);
                Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                  Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Background: (Color: #1e2530);
                  $C.@TextField #FieldHealth0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldHealth1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldHealth2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldHealth3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldHealth4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Label #ChangedHealth { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                  Label #ModifiedHealth { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                }
              }
              Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
              Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 6);
                Label { Text: "Damage Scaling"; Style: @SectionHeaderStyle; Anchor: (Width: 160, Height: 20); }
                Group { Anchor: (Width: 38, Height: 28); TextButton #DamageScalingOn { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #DamageScalingOff { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                Label #ChangedDamageScaling { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedDamageScaling { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Label { Text: "Scales elite damage output by a multiplier per tier. Disable to use vanilla damage values."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); }
              Label { Text: "Damage Multiplier Per Tier"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Top; Anchor: (Left: 0, Width: 410);
                Group { LayoutMode: Left; Background: #1a2332(0.8); Padding: (Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                  Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                  Group { Anchor: (Width: 12); }
                  Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 70); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8); Background: (Color: #1e2530);
                  $C.@TextField #FieldDamage0 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldDamage1 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldDamage2 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldDamage3 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Group { Anchor: (Width: 12); }
                  $C.@TextField #FieldDamage4 { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                  Label #ChangedDamage { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                  Label #ModifiedDamage { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                }
              }

              Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
              Label { Text: "Random Variance"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 6); }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Health Variance"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldHealthVariance { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedHealthVariance { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "e.g. 0.05 = +/-5% random HP"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
              }
              Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                Label { Text: "Damage Variance"; Style: @FieldLabelStyle; Anchor: (Width: 300); }
                $C.@TextField #FieldDamageVariance { Anchor: (Width: 70, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ModifiedDamageVariance { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label { Text: "e.g. 0.05 = +/-5% random DMG"; Anchor: (Left: 8); Style: (FontSize: 13, TextColor: #7a8da0, VerticalAlignment: Center); }
              }
            }

            Group #TabWorldAbilities { LayoutMode: Top; Visible: false;
              Label { Text: "GLOBAL ABILITY COOLDOWN"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 4); }
              Label { Text: "Minimum delay between consecutive abilities on a single elite."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 4); }
              Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 2);
                Label { Text: "Cooldown Min (s):"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                $C.@TextField #FieldGlobalCdMin { Anchor: (Width: 60, Height: 28); Style: (FontSize: 14, TextColor: #ffffff); }
                Label #ChangedGlobalCdMin { Text: "  *"; Style: (FontSize: 14, TextColor: #4ade80, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
                Label #ModifiedGlobalCdMin { Text: " *"; Style: (FontSize: 14, TextColor: #e8a838, VerticalAlignment: Center); Anchor: (Width: 20); Visible: false; }
              }
              Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 2);
                Label { Text: "Cooldown Max (s):"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
