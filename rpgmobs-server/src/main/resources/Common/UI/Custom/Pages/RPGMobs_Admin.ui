                  Group #AbilCfgGateRow3 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false; Label #AbilCfgGateName3 { Text: ""; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); } Group { Anchor: (Width: 24, Height: 22); TextButton #AbilCfgGatePeek3 { Text: ">"; Anchor: (Width: 24, Height: 22); Style: @SubTabStyle; } } Group { Anchor: (Width: 4); } TextButton #AbilCfgGateDel3 { Text: "X"; Anchor: (Width: 24, Height: 22); Style: @DeleteRowButtonStyle; } }
                  Group #AbilCfgGateRow4 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false; Label #AbilCfgGateName4 { Text: ""; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); FlexWeight: 1; Padding: (Left: 8); } Group { Anchor: (Width: 24, Height: 22); TextButton #AbilCfgGatePeek4 { Text: ">"; Anchor: (Width: 24, Height: 22); Style: @SubTabStyle; } } Group { Anchor: (Width: 4); } TextButton #AbilCfgGateDel4 { Text: "X"; Anchor: (Width: 24, Height: 22); Style: @DeleteRowButtonStyle; } }
                  Group #AbilCfgGatePagination { LayoutMode: Left; Anchor: (Height: 28, Top: 2); Visible: false;
                    Group { FlexWeight: 1; }
