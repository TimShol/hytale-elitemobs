            Group #TabWorldMobRules { LayoutMode: Top; Visible: false;

              Label { Text: "Mob Rules"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 8); }
              Label #PerWorldMobRuleSummary { Text: ""; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); Visible: false; }

              Group #MobRuleBreadcrumb {
                LayoutMode: Left;
                Anchor: (Height: 30, Bottom: 8);
                Background: (Color: #0f1620);
                Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);

                TextButton #MobRuleNavBack { Text: "<"; Anchor: (Width: 28, Height: 24); Style: @PaginationButtonStyle; }
                TextButton #MobRuleNavForward { Text: ">"; Anchor: (Width: 28, Height: 24, Left: 4); Style: @PaginationButtonStyle; }
                Label #MobRuleBreadcrumbText { Text: "> All"; FlexWeight: 1; Anchor: (Left: 12); Style: (FontSize: 13, TextColor: #c8d6e5, VerticalAlignment: Center); }
              }

              Group #MobRuleFilterBar { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                Label { Text: "Search Mob Rules:"; Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 120); }
                $C.@TextField #MobRuleTreeFilter { Anchor: (Width: 150, Height: 26); Style: (FontSize: 13, TextColor: #c8d6e5); }
                Group { FlexWeight: 1; }
                TextButton #MobRuleDeleteFiltered { Text: "Delete Filtered"; Anchor: (Width: 110, Height: 26); Style: @DeleteRowButtonStyle; Visible: false; }
                Group { Anchor: (Width: 4); }
                TextButton #MobRuleDeleteAll { Text: "Delete All"; Anchor: (Width: 80, Height: 26); Style: @DeleteRowButtonStyle; }
              }

