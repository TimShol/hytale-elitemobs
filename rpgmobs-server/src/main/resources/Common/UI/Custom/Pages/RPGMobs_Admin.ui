              Label #LootTreeEmpty { Text: "No items at this level. Use [+] to add categories or loot templates."; Style: (FontSize: 13, TextColor: #5a6d82); Anchor: (Height: 24, Top: 4); Visible: false; }

              Group #LootTemplateDetail { LayoutMode: Top; Visible: false; Background: (Color: #161d28); Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8); Anchor: (Left: 0, Width: 600, Bottom: 8);

                Label #LootTplDetailTitle { Text: ""; Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true); Anchor: (Height: 20, Bottom: 4); }
                Label { Text: "LINKED MOB RULES"; Style: (FontSize: 13, TextColor: #8ab4f8, RenderBold: true); Anchor: (Height: 18, Bottom: 4); }
                Label { Text: "Mobs linked here will receive drops from this template. Add by category or individual mob."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 4); }
                Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                  Label { Text: "Search Mobs:"; Style: (FontSize: 13, TextColor: #c8d6e5, VerticalAlignment: Center); Anchor: (Width: 90, Height: 26); }
                  $C.@TextField #LootTplMobFilter { Anchor: (Width: 150, Height: 26); Style: (FontSize: 13, TextColor: #c8d6e5); }
                }
                Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4);
                  TextButton #LootTplAddCategory { Text: "[+] Category"; Anchor: (Width: 120, Height: 26); Style: @SubTabStyle; }
                  Group { Anchor: (Width: 4); }
                  TextButton #LootTplAddMob { Text: "[+] Mob Rule"; Anchor: (Width: 120, Height: 26); Style: @SubTabStyle; }
                }
                Group #LootTplMobRow0 { LayoutMode: Left; Anchor: (Height: 24, Bottom: 1); Visible: false; Label #LootTplMobNameCat0 { Text: ""; Style: (FontSize: 13, TextColor: #8ab4f8, RenderBold: true, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); Padding: (Left: 6); Visible: false; } Label #LootTplMobNameMob0 { Text: ""; Style: (FontSize: 13, TextColor: #4ade80, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 24); Padding: (Left: 6); Visible: false; } Group { Anchor: (Width: 24, Height: 24); TextButton #LootTplMobPeek0 { Text: ">"; Anchor: (Width: 24, Height: 22); Style: @SubTabStyle; Visible: false; } } Group { Anchor: (Width: 2); } TextButton #LootTplMobDel0 { Text: "X"; Anchor: (Width: 24, Height: 24); Style: @DeleteRowButtonStyle; } }
