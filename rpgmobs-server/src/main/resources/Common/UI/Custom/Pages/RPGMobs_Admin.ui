      Group #CatPeekPagination { LayoutMode: Left; Anchor: (Height: 28, Top: 4); Visible: false;
        Group { FlexWeight: 1; }
        Group { Anchor: (Width: 26, Height: 26); TextButton #CatPeekFirstPage { Text: "<<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
        Group { Anchor: (Width: 2); }
        Group { Anchor: (Width: 26, Height: 26); TextButton #CatPeekPrevPage { Text: "<"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
        Group { Anchor: (Width: 4); }
        Label #CatPeekPageInfo { Text: ""; Style: (FontSize: 13, TextColor: #5a6d82, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Width: 80, Height: 26); }
        Group { Anchor: (Width: 4); }
        Group { Anchor: (Width: 26, Height: 26); TextButton #CatPeekNextPage { Text: ">"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
        Group { Anchor: (Width: 2); }
        Group { Anchor: (Width: 26, Height: 26); TextButton #CatPeekLastPage { Text: ">>"; Anchor: (Width: 26, Height: 26); Style: @SubTabStyle; } }
        Group { FlexWeight: 1; }
      }

      Group { Anchor: (Height: 4); }
      Label #CatPeekExtractInfo { Text: "Replace the category with its individual items."; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 4); Visible: false; }
      Group { LayoutMode: Left; Anchor: (Height: 32);
        TextButton #CatPeekClose { Text: "Close"; Anchor: (Width: 100, Height: 30); Style: @SubTabStyle; }
        Group { FlexWeight: 1; }
        TextButton #CatPeekExtract { Text: "Extract Items"; Anchor: (Width: 120, Height: 30); Style: @SubTabStyle; Visible: false; }
      }
    }
  }

  Group #AssetPickerPopup {
    Anchor: (Width: 1200, Height: 880);
    Background: (Color: #00000080);
    Visible: false;

    TextButton #AssetPickerBackdrop { Text: ""; Anchor: (Width: 1200, Height: 880); Style: @BackdropStyle; }

    Group {
      Anchor: (Width: 480, Height: 740);
      Background: (Color: #141c26);
      LayoutMode: Top;
      Padding: (Left: 18, Right: 18, Top: 14, Bottom: 14);

      Label #AssetPickerTitle { Text: "Select Asset"; Style: (FontSize: 17, TextColor: #c8d6e5, RenderBold: true); Anchor: (Height: 26, Bottom: 4); }
      Label #AssetPickerSubtitle { Text: ""; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16, Bottom: 6); }

      Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 6);
        Label { Text: "Filter:"; Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 46); }
        $C.@TextField #AssetPickerFilter { Anchor: (Width: 390, Height: 28); Style: (FontSize: 14, TextColor: #c8d6e5); }
      }

