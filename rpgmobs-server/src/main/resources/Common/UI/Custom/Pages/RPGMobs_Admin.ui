              Group #GlobMobRuleDetailPanel { LayoutMode: Top; Visible: false; Background: (Color: #161d28); Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10); Anchor: (Left: 0, Width: 480, Bottom: 8);

                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 8);
                  Label #GlobMobRuleDetailTitle { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: #4ade80, RenderBold: true, VerticalAlignment: Center); }
                  TextButton #GlobMobRuleRebind { Text: "Change NPC"; Anchor: (Width: 100, Height: 28); Style: @SubTabStyle; }
                }

                Label { Text: "MATCHING"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 4); }

                Group { LayoutMode: Top; Anchor: (Bottom: 4); Background: (Color: #1e2530); Padding: (Left: 8, Bottom: 2);
                  Group { LayoutMode: Left; Anchor: (Height: 34);
                    Label { Text: "Exact"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                    $C.@TextField #FieldGlobMobRuleMatchExact { FlexWeight: 1; Anchor: (Height: 28); Style: (FontSize: 14, TextColor: #c8d6e5); }
                  }
                  Label { Text: "e.g. Goblin_Warrior, Trork_Brute"; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16); }
                }
                Group { LayoutMode: Top; Anchor: (Bottom: 4); Background: (Color: #1e2530); Padding: (Left: 8, Bottom: 2);
                  Group { LayoutMode: Left; Anchor: (Height: 34);
                    Label { Text: "Starts With"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                    $C.@TextField #FieldGlobMobRuleMatchPrefix { FlexWeight: 1; Anchor: (Height: 28); Style: (FontSize: 14, TextColor: #c8d6e5); }
                  }
                  Label { Text: "e.g. Goblin_, Trork_"; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16); }
                }
                Group { LayoutMode: Top; Anchor: (Bottom: 4); Background: (Color: #1e2530); Padding: (Left: 8, Bottom: 2);
                  Group { LayoutMode: Left; Anchor: (Height: 34);
                    Label { Text: "Contains"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                    $C.@TextField #FieldGlobMobRuleMatchContains { FlexWeight: 1; Anchor: (Height: 28); Style: (FontSize: 14, TextColor: #c8d6e5); }
                  }
                  Label { Text: "e.g. Goblin, Undead"; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16); }
                }
                Group { LayoutMode: Top; Anchor: (Bottom: 8); Background: (Color: #1e2530); Padding: (Left: 8, Bottom: 2);
                  Group { LayoutMode: Left; Anchor: (Height: 34);
                    Label { Text: "Excludes"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                    $C.@TextField #FieldGlobMobRuleMatchExcludes { FlexWeight: 1; Anchor: (Height: 28); Style: (FontSize: 14, TextColor: #c8d6e5); }
                  }
                  Label { Text: "e.g. Boss, Miniboss"; Style: (FontSize: 13, TextColor: #7a8da0); Anchor: (Height: 16); }
                }

                Group { Anchor: (Height: 1, Top: 4, Bottom: 6); Background: (Color: #2a3a4a); }
                Label { Text: "WEAPON OVERRIDES"; Style: @SectionHeaderStyle; Anchor: (Height: 20, Bottom: 4); }

                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 4); Background: (Color: #1e2530); Padding: (Left: 8);
                  Label { Text: "Override Mode"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                  TextButton #GlobMobRuleCycleMode { Text: "ALWAYS"; Anchor: (Width: 140, Height: 30); Style: @SubTabStyle; }
                }

                Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 4); Background: (Color: #1e2530); Padding: (Left: 8);
                  Label { Text: "Combat Style"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                  TextButton #GlobMobRuleCombatStyle { Text: "Auto"; Anchor: (Width: 140, Height: 30); Style: @SubTabStyle; }
                }

                Group #GlobMobRuleWpnTierTable { LayoutMode: Top; Anchor: (Left: 0, Width: 380, Bottom: 4);
                  Group { LayoutMode: Left; Background: (Color: #1a2332); Padding: (Left: 8, Top: 3, Bottom: 3); Anchor: (Height: 24, Bottom: 2);
                    Label { Text: ""; Style: @ColHeaderStyle; Anchor: (Width: 130); }
                    Label { Text: "T1"; Style: @ColHeaderStyle; Anchor: (Width: 38); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T2"; Style: @ColHeaderStyle; Anchor: (Width: 38); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T3"; Style: @ColHeaderStyle; Anchor: (Width: 38); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T4"; Style: @ColHeaderStyle; Anchor: (Width: 38); }
                    Group { Anchor: (Width: 12); }
                    Label { Text: "T5"; Style: @ColHeaderStyle; Anchor: (Width: 38); }
                  }
                  Group { LayoutMode: Left; Anchor: (Height: 34, Bottom: 2); Background: (Color: #1e2530); Padding: (Left: 8);
                    Label { Text: "Enabled"; Style: @FieldLabelStyle; Anchor: (Width: 130); }
                    Group { Anchor: (Width: 38, Height: 28); TextButton #GlobMobRuleWpnTierOn0 { Text: "ON"; Anchor: (Width: 38, Height: 28); Style: @ToggleOnStyle; Visible: false; } TextButton #GlobMobRuleWpnTierOff0 { Text: "OFF"; Anchor: (Width: 38, Height: 28); Style: @ToggleOffStyle; Visible: false; } }
                    Group { Anchor: (Width: 12); }
