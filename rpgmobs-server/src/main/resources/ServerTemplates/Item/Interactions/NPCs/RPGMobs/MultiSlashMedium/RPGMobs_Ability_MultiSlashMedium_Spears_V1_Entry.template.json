{
  "Type": "Serial",
  "$Comment": "RPGMobs MultiSlashMedium Spears V1  - 3-hit stab + spin combo (~3.5s total). Uses SFX_Spear sounds.",
  "Interactions": [
    {
      "Type": "Simple",
      "$Comment": "Wind-up  - 1.6s spear pulled back with Mace_Signature trail on weapon",
      "RunTime": 1.0,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "ThrowCharging",
        "WorldSoundEventId": "SFX_Spear_Throw_Charge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ],
        "MovementEffects": { "DisableAll": true }
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 1  - Stab forward thrust",
      "RunTime": 0.45,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "Stab",
        "WorldSoundEventId": "SFX_Spear_Lunge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.8 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashMedium.config.templates.damageInteractionSpears} ]
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 2  - SpinSwingLeft spinning sweep",
      "RunTime": 0.5,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "SpinSwingLeft",
        "WorldSoundEventId": "SFX_Spear_Lunge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.8 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashMedium.config.templates.damageInteractionSpears} ]
      }
    },
    {
      "Type": "Serial",
      "$Comment": "Hit 3  - SpinSwingRightHeavy FINISHER heavy spin with forward drift + dual trails + impact VFX",
      "Interactions": [
        {
          "Type": "ApplyForce",
          "Force": ${features.MultiSlashMedium.config.forwardDriftForcePerTier},
          "Direction": { "X": 0, "Y": 0.05, "Z": -1.0 },
          "WaitForGround": false,
          "ChangeVelocityType": "Add",
          "VelocityConfig": {
            "AirResistance": 0.90, "AirResistanceMax": 0.85,
            "GroundResistance": 0.85, "GroundResistanceMax": 0.70,
            "Threshold": 0.1, "Style": "Exp"
          }
        },
        {
          "Type": "Selector",
          "RunTime": 0.7,
          "Effects": {
            "ItemPlayerAnimationsId": "Spear",
            "ItemAnimationId": "SpinSwingRightHeavy",
            "WorldSoundEventId": "SFX_Spear_Lunge",
            "Particles": [
              {
                "SystemId": "Mace_Signature_Cast",
                "DetachedFromModel": true
              }
            ],
            "Trails": [
              {
                "TrailId": "Mace_Signature",
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              },
              {
                "TrailId": "Mace_Signature2",
                "RotationOffset": { "Roll": 90.0 },
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              }
            ]
          },
          "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.2 }, "Range": 3.2 },
          "HitEntity": {
            "Interactions": [ ${features.MultiSlashMedium.config.templates.damageInteractionSpears} ]
          }
        }
      ]
    },
    {
      "Type": "Simple",
      "$Comment": "Recovery  - Idle recovery, movement locked",
      "RunTime": 0.4,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "Idle",
        "ClearAnimationOnFinish": true,
        "MovementEffects": { "DisableAll": true }
      }
    }
  ]
}
