{
  "Type": "Serial",
  "$Comment": "RPGMobs MultiSlashMedium Maces V1  - 2-hit side swing + slam (~3.4s total). Uses SFX_Mace_T2 sounds.",
  "Interactions": [
    {
      "Type": "Simple",
      "$Comment": "Wind-up  - 1.1s slam charge with Medium_Mace_Charged trail on weapon",
      "RunTime": 1.1,
      "Effects": {
        "ItemPlayerAnimationsId": "Mace",
        "ItemAnimationId": "SwingDownCharging",
        "WorldSoundEventId": "SFX_Mace_T2_Raise",
        "Trails": [
          {
            "TrailId": "Medium_Mace_Charged",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ],
        "MovementEffects": { "DisableAll": true }
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 1  - SwingLeftCharged side swing",
      "RunTime": 0.40,
      "Effects": {
        "ItemPlayerAnimationsId": "Mace",
        "ItemAnimationId": "SwingLeftCharged",
        "WorldSoundEventId": "SFX_Mace_T2_Swing_Charged",
        "Trails": [
          {
            "TrailId": "Medium_Mace_Charged",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.5 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashMedium.config.templates.damageInteractionMaces} ]
      }
    },
    {
      "Type": "Serial",
      "$Comment": "Hit 2  - SwingDownCharged FINISHER overhead slam with forward drift + dual trails + impact VFX, rooted",
      "Interactions": [
        {
          "Type": "ApplyForce",
          "Force": ${features.MultiSlashMedium.config.forwardDriftForcePerTier},
          "Direction": { "X": 0, "Y": 0.08, "Z": -1.5 },
          "WaitForGround": false,
          "ChangeVelocityType": "Add",
          "VelocityConfig": {
            "AirResistance": 0.90, "AirResistanceMax": 0.85,
            "GroundResistance": 0.85, "GroundResistanceMax": 0.70,
            "Threshold": 0.1, "Style": "Exp"
          }
        },
        {
          "Type": "Selector",
          "RunTime": 0.6,
          "Effects": {
            "ItemPlayerAnimationsId": "Mace",
            "ItemAnimationId": "SwingDownCharged",
            "WorldSoundEventId": "SFX_Mace_T2_Swing",
            "Particles": [
              {
                "SystemId": "Mace_Signature_Slash",
                "TargetEntityPart": "Entity",
                "TargetNodeName": "Hip",
                "PositionOffset": { "Y": 1.5, "Z": -0.5 }
              },
              {
                "SystemId": "Mace_Signature_Cast",
                "TargetEntityPart": "Entity",
                "TargetNodeName": "Hip",
                "PositionOffset": { "Y": 0.5 }
              }
            ],
            "Trails": [
              {
                "TrailId": "Mace_Signature",
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              },
              {
                "TrailId": "Mace_Signature2",
                "RotationOffset": { "Roll": 90.0 },
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              }
            ]
          },
          "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.5 }, "Range": 3.0 },
          "HitEntity": {
            "Interactions": [ ${features.MultiSlashMedium.config.templates.damageInteractionMaces} ]
          }
        }
      ]
    },
    {
      "Type": "Simple",
      "$Comment": "Recovery  - Idle recovery, movement locked",
      "RunTime": 0.5,
      "Effects": {
        "ItemPlayerAnimationsId": "Mace",
        "ItemAnimationId": "Idle",
        "ClearAnimationOnFinish": true,
        "MovementEffects": { "DisableAll": true }
      }
    }
  ]
}
