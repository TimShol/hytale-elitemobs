{
  "Type": "Serial",
  "$Comment": "RPGMobs MultiSlashLong Spears  - 5-hit thrust + spin sequence (~6.2s total). ThrowCharging→ThrowCharged flows naturally (no idle gap). Slower hit timings for visible animations. Uses SFX_Spear sounds.",
  "Interactions": [
    {
      "Type": "Simple",
      "$Comment": "Wind-up  - 2.1s spear pulled back with Mace_Signature trail on weapon",
      "RunTime": 1.2,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "ThrowCharging",
        "WorldSoundEventId": "SFX_Spear_Throw_Charge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ],
        "MovementEffects": { "DisableAll": true }
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 1  - ThrowCharged forward thrust (flows naturally from ThrowCharging, no idle gap). Impact sound on this stab.",
      "RunTime": 0.35,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "ThrowCharged",
        "WorldSoundEventId": "SFX_Spear_Lunge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.5 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashLong.config.templates.damageInteractionSpears} ]
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 2  - SpinSwingLeft light spin",
      "RunTime": 0.5,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "SpinSwingLeft",
        "WorldSoundEventId": "SFX_Spear_Lunge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.5 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashLong.config.templates.damageInteractionSpears} ]
      }
    },
    {
      "Type": "Selector",
      "$Comment": "Hit 3  - SpinSwingRight light spin",
      "RunTime": 0.5,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "SpinSwingRight",
        "WorldSoundEventId": "SFX_Spear_Lunge",
        "Trails": [
          {
            "TrailId": "Mace_Signature",
            "TargetEntityPart": "PrimaryItem",
            "TargetNodeName": "Origin_Projectile",
            "PositionOffset": { "Y": -0.2 }
          }
        ]
      },
      "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.0 }, "Range": 2.5 },
      "HitEntity": {
        "Interactions": [ ${features.MultiSlashLong.config.templates.damageInteractionSpears} ]
      }
    },
    {
      "Type": "Serial",
      "$Comment": "Hit 4  - SpinSwingLeftHeavy with forward drift + dual trails + cast particle",
      "Interactions": [
        {
          "Type": "ApplyForce",
          "Force": ${features.MultiSlashLong.config.forwardDriftForcePerTier},
          "Direction": { "X": 0, "Y": 0.05, "Z": -1.0 },
          "WaitForGround": false,
          "ChangeVelocityType": "Add",
          "VelocityConfig": {
            "AirResistance": 0.90, "AirResistanceMax": 0.85,
            "GroundResistance": 0.85, "GroundResistanceMax": 0.70,
            "Threshold": 0.1, "Style": "Exp"
          }
        },
        {
          "Type": "Selector",
          "RunTime": 0.7,
          "Effects": {
            "ItemPlayerAnimationsId": "Spear",
            "ItemAnimationId": "SpinSwingLeftHeavy",
            "WorldSoundEventId": "SFX_Spear_Lunge",
            "Particles": [
              {
                "SystemId": "Mace_Signature_Cast",
                "DetachedFromModel": true
              }
            ],
            "Trails": [
              {
                "TrailId": "Mace_Signature",
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              },
              {
                "TrailId": "Mace_Signature2",
                "RotationOffset": { "Roll": 90.0 },
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              }
            ]
          },
          "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.2 }, "Range": 2.8 },
          "HitEntity": {
            "Interactions": [ ${features.MultiSlashLong.config.templates.damageInteractionSpears} ]
          }
        }
      ]
    },
    {
      "Type": "Serial",
      "$Comment": "Hit 5  - SpinSwingRightHeavy FINISHER with strong forward lunge + impact burst",
      "Interactions": [
        {
          "Type": "ApplyForce",
          "Force": ${features.MultiSlashLong.config.forwardDriftForcePerTier},
          "Direction": { "X": 0, "Y": 0.08, "Z": -1.5 },
          "WaitForGround": false,
          "ChangeVelocityType": "Add",
          "VelocityConfig": {
            "AirResistance": 0.90, "AirResistanceMax": 0.85,
            "GroundResistance": 0.85, "GroundResistanceMax": 0.70,
            "Threshold": 0.1, "Style": "Exp"
          }
        },
        {
          "Type": "Selector",
          "RunTime": 0.7,
          "Effects": {
            "ItemPlayerAnimationsId": "Spear",
            "ItemAnimationId": "SpinSwingRightHeavy",
            "WorldSoundEventId": "SFX_Spear_Lunge",
            "Particles": [
              {
                "SystemId": "Mace_Signature_Cast",
                "DetachedFromModel": true
              }
            ],
            "Trails": [
              {
                "TrailId": "Mace_Signature",
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              },
              {
                "TrailId": "Mace_Signature2",
                "RotationOffset": { "Roll": 90.0 },
                "TargetEntityPart": "PrimaryItem",
                "TargetNodeName": "Origin_Projectile",
                "PositionOffset": { "Y": -0.2 }
              }
            ]
          },
          "Selector": { "Id": "AOECircle", "Offset": { "Z": -1.5 }, "Range": 3.2 },
          "HitEntity": {
            "Interactions": [ ${features.MultiSlashLong.config.templates.damageInteractionSpears} ]
          }
        }
      ]
    },
    {
      "Type": "Simple",
      "$Comment": "Recovery  - Idle recovery, movement locked",
      "RunTime": 0.6,
      "Effects": {
        "ItemPlayerAnimationsId": "Spear",
        "ItemAnimationId": "Idle",
        "ClearAnimationOnFinish": true,
        "MovementEffects": { "DisableAll": true }
      }
    }
